<Project Sdk="Microsoft.NET.Sdk.Web">

  <PropertyGroup>
    <TargetFramework>net10.0</TargetFramework>
    <Nullable>enable</Nullable>
    <ImplicitUsings>enable</ImplicitUsings>
    <SpaRoot>./</SpaRoot>
  </PropertyGroup>

  <!-- Auto-compile React App (Vite PWA) before building .NET assembly -->
  <Target Name="BuildReactApp" BeforeTargets="Build" Condition="'$(Configuration)' == 'Debug' Or '$(Configuration)' == 'Release'">
    <Message Importance="high" Text="[Human Music Backend] Triggering npm build for client React application..." />
    <Exec Command="npm run build" WorkingDirectory="$(SpaRoot)" />
  </Target>

</Project>
